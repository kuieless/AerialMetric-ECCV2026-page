{
    "data": {
        "aspect_ratio_range": [0.5, 2.0],
        "area_range": [250000, 600000],
        "clamp_max_depth": 500.0,
        "center_augmentation": 0.5,
        "fov_range_absolute": [30, 120],
        "fov_range_relative": [0.5, 1.0],
        "image_augmentation": [],
        "datasets": [ 
            {
                "name": "GAU",
                "path": "/home/data1/szq/Megadepth/Benchmark-final2/TrainingData_Final_MoGe-All",
                "label_type": "SFM",
                "weight": 1.0,
                "depth_unit": 1.0,
                "index": ".index.txt",
                "depth": "depth.npy",
                "center_augmentation": 0.25,
                "fov_range_absolute": [30, 120],
                "fov_range_relative": [0.8, 1.0],
                "image_augmentation": []
            }
        ]
    },
    "model_version": "v2",
    "model": {
        "encoder": {
            "backbone": "dinov2_vits14",
            "intermediate_layers": [5, 11],
            "dim_out": 384
        },
        "neck": {
            "dim_in": [386, 2, 2, 2, 2],
            "dim_out": null,
            "dim_res_blocks": [384, 256, 128, 64, 32],
            "num_res_blocks": [0, 1, 1, 1, 0],
            "res_block_in_norm": "none",
            "res_block_hidden_norm": "none",
            "resamplers": ["conv_transpose", "conv_transpose", "conv_transpose", "bilinear"]
        },
        "points_head": {
            "dim_in": [384, 256, 128, 64, 32],
            "dim_out": [null, null, null, null, 3],
            "dim_res_blocks": [384, 256, 128, 64, 32],
            "num_res_blocks": [0, 1, 1, 1, 0],
            "res_block_in_norm": "none",
            "res_block_hidden_norm": "none",
            "resamplers": ["conv_transpose", "conv_transpose", "conv_transpose", "bilinear"]
        },
        "normal_head": {
            "dim_in": [384, 256, 128, 64, 32],
            "dim_out": [null, null, null, null, 3],
            "dim_res_blocks": [384, 256, 128, 64, 32],
            "num_res_blocks": [0, 1, 1, 1, 0],
            "res_block_in_norm": "none",
            "res_block_hidden_norm": "none",
            "resamplers": ["conv_transpose", "conv_transpose", "conv_transpose", "bilinear"]
        },
        "mask_head": {
            "dim_in": [384, 256, 128, 64, 32],
            "dim_out": [null, null, null, null, 1],
            "dim_res_blocks": [384, 256, 128, 64, 32],
            "num_res_blocks": [0, 1, 1, 1, 0],
            "res_block_in_norm": "none",
            "res_block_hidden_norm": "none",
            "resamplers": ["conv_transpose", "conv_transpose", "conv_transpose", "bilinear"]
        },
        "scale_head": {
            "dims": [384, 384, 384, 1]
        },
        "remap_output": "exp",
        "num_tokens_range": [1024, 2500]
    },
    "optimizer": {
        "type": "AdamW",
        "params": [
            {"params": {"include": ["*"], "exclude": ["*.backbone.*"]}, "lr": 5e-5},
            {"params": {"include": ["*.backbone.*"]}, "lr": 1e-6}
        ]
    },
    "lr_scheduler": {
        "type": "SequentialLR",
        "params": {
            "schedulers": [
                {"type": "LambdaLR", "params": {"lr_lambda": ["1.0", "max(0.0, min(1.0, (epoch - 1000) / 1000))"]}},
                {"type": "StepLR", "params": {"step_size": 25000, "gamma": 0.5}}
            ],
            "milestones": [2000]
        }
    },
    "low_resolution_training_steps": 0,
    "loss": {
        "SFM": {
            "global": {"function": "affine_invariant_global_loss", "weight": 1.0, "params": {"align_resolution": 48}},
  
            "metric_scale": {"function": "metric_scale_loss", "weight": 0.5},
            "mask": {"function": "mask_bce_loss", "weight": 0.1}
        }
    }
}